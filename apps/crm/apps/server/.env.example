# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS
CORS_ORIGIN=http://localhost:3001
TALLER_URL=http://localhost:3000
FRONT_URL=http://localhost:3001

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_DOMAIN=pub-e8fc0de6a599420ea473808b97217fdd.r2.dev

# R2 Buckets (standardized naming: R2_BUCKET_*)
R2_BUCKET_CRM=crm-documents
R2_BUCKET_LEGAL_DOCS=legal-documents
# Legacy names (deprecated, use R2_BUCKET_* instead)
# R2_BUCKET_NAME=crm-documents
# R2_BUCKET_NAME_LEGAL_DOCS=legal-documents

# Cartera-Back Integration
CARTERA_BACK_URL=http://localhost:7000
# Credenciales para login contra cartera-back (/auth/login). El JWT
# devuelto se cachea y refresca automáticamente.
CARTERA_USER=
CARTERA_PASSWORD=
CARTERA_BACK_TIMEOUT=30000
CARTERA_BACK_RETRY_ATTEMPTS=3
CARTERA_BACK_ENABLE_CACHE=true
CARTERA_BACK_CACHE_TTL=300000

# Feature Flags
ENABLE_CARTERA_BACK_INTEGRATION=false
ENABLE_CARTERA_BACK_PAYMENTS=false
ENABLE_CARTERA_BACK_SYNC_JOB=false

# Sync Settings
COBROS_SYNC_INTERVAL_MINUTES=60

# Legal Docs API
LEGAL_API_URL=https://api.devteamatcci.site
LEGAL_DOCS_API_URL=https://legal-docs-blueprints.s4.devteamatcci.site
