# Puerto donde corre el servidor
PORT=4000

# Gotenberg Configuration (para convertir DOCX a PDF)
# Si usas docker-compose, Gotenberg estará en el puerto 3030
GOTENBERG_URL=http://localhost:3030

# Configuración de Documenso
DOCUMENSO_API_TOKEN=your_api_token_here
DOCUMENSO_BASE_URL=https://documenso.s2.devteamatcci.site/api/v2-beta

# Configuración de WeeTrust (firma electrónica)
# Sandbox: https://api-sandbox.weetrust.com.mx
# Producción: https://api.weetrust.mx
WEETRUST_API_URL=https://api-sandbox.weetrust.com.mx
WEETRUST_USER_ID=your_user_id_here
WEETRUST_API_KEY=your_api_key_here
# Webhook secret for validating incoming webhook requests (generate a random string)
WEETRUST_WEBHOOK_SECRET=your_webhook_secret_here

# Integración con CRM (para guardar contratos generados automáticamente)
CRM_API_URL=http://localhost:3000
CRM_SERVICE_ACCOUNT_EMAIL=legaldocs@clubcashin.com
CRM_SERVICE_ACCOUNT_PASSWORD=your_service_account_password_here

# Cloudflare R2 (para subir PDFs directamente, independiente de firma electrónica)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_LEGAL_DOCS=legal-documents
