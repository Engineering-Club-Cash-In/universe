    "test:integration": "INTEGRATION=true vitest run __tests__/integration.test.ts"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "elysia": "^1.1.29"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}